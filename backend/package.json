{
  "name": "nr-safety-alerts-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Sprint 1 starter — real-time alert ingestion for NR Safety Alerts CMT Dashboard",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "ingest": "tsx src/workers/scheduler.ts",
    "migrate": "psql $DATABASE_URL -f migrations/001_init.sql && psql $DATABASE_URL -f migrations/002_geocode_and_sources.sql && psql $DATABASE_URL -f seeds/offices.sql",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
