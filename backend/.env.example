# Backend configuration — copy to .env and adjust as needed.
DATABASE_URL=postgres://nrsa:nrsa@localhost:5432/nrsa
PORT=8080
LOG_LEVEL=info

# Per-source overrides (seconds). Defaults are sane.
USGS_FETCH_INTERVAL=60
NWS_FETCH_INTERVAL=300

# Set to "true" to disable a source without removing it
USGS_DISABLED=false
NWS_DISABLED=false
EONET_DISABLED=false
GDACS_DISABLED=false
EMSC_DISABLED=false
METEOALARM_DISABLED=false
STATE_DEPT_DISABLED=false
SF_POLICE_DISABLED=false
ATL_APD_DISABLED=false
PDX_FLASHALERT_DISABLED=false
LONDON_TFL_DISABLED=false

# Per-source intervals (seconds) — see config.ts for defaults
EONET_FETCH_INTERVAL=600
GDACS_FETCH_INTERVAL=600
EMSC_FETCH_INTERVAL=300
METEOALARM_FETCH_INTERVAL=900
STATE_DEPT_FETCH_INTERVAL=86400
SF_POLICE_FETCH_INTERVAL=600
ATL_APD_FETCH_INTERVAL=900
PDX_FLASHALERT_FETCH_INTERVAL=600
LONDON_TFL_FETCH_INTERVAL=600

# Geocoding (Nominatim public service is rate-limited to 1 req/sec)
# Switch NOMINATIM_URL to http://localhost:7070/search after running `docker compose --profile geocode up -d`
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=nr-safety-alerts/0.1 (cmt-dashboard@example.com)
GEOCODE_CACHE_TTL_DAYS=180

# Optional: change the Nominatim region (default: Liechtenstein for fast first boot)
# PBF_URL=https://download.geofabrik.de/north-america-latest.osm.pbf
# REPLICATION_URL=https://download.geofabrik.de/north-america-updates/

# Webhook for source-down / source-recovery alerts.
# Auto-detects Slack / PagerDuty / generic by URL. Empty = log-only (default).
# Slack:     https://hooks.slack.com/services/T0000/B0000/XXXX
# PagerDuty: https://events.pagerduty.com/v2/enqueue   (set PAGERDUTY_ROUTING_KEY too)
WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# GDELT (heavy firehose; 15-min cadence)
GDELT_DISABLED=false
GDELT_FETCH_INTERVAL=900

# Auth — JWT signing secret. CHANGE FOR PRODUCTION.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-only-do-not-use-in-prod-please-rotate
JWT_EXPIRES_IN=12h

# Optional: when integrated with Okta, set these to verify Okta-issued JWTs
# instead of accepting locally-issued ones. Leave blank for the prototype.
OKTA_ISSUER=
OKTA_AUDIENCE=
OKTA_JWKS_URI=

# CORS — origin of the dashboard (http://localhost:8000 for local file://, or your Pages URL)
CORS_ORIGIN=*
