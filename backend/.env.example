# Backend configuration — copy to .env and adjust as needed.
DATABASE_URL=postgres://nrsa:nrsa@localhost:5432/nrsa
PORT=8080
LOG_LEVEL=info

# Per-source overrides (seconds). Defaults are sane.
USGS_FETCH_INTERVAL=60
NWS_FETCH_INTERVAL=300

# Set to "true" to disable a source without removing it
USGS_DISABLED=false
NWS_DISABLED=false
EONET_DISABLED=false
GDACS_DISABLED=false
EMSC_DISABLED=false
METEOALARM_DISABLED=false
STATE_DEPT_DISABLED=false

# Per-source intervals (seconds) — see config.ts for defaults
EONET_FETCH_INTERVAL=600
GDACS_FETCH_INTERVAL=600
EMSC_FETCH_INTERVAL=300
METEOALARM_FETCH_INTERVAL=900
STATE_DEPT_FETCH_INTERVAL=86400

# Geocoding (Nominatim public service is rate-limited to 1 req/sec)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=nr-safety-alerts/0.1 (cmt-dashboard@example.com)
GEOCODE_CACHE_TTL_DAYS=180

# CORS — origin of the dashboard (http://localhost:8000 for local file://, or your Pages URL)
CORS_ORIGIN=*
